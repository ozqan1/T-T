{
  "expo": {
    "name": "TİT",
    "slug": "akrep-indirici",
    "version": "10.9.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "akrep",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nebiozkan.akrep",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Uygulamayı ve indirdiğiniz videoları korumak için Face ID kullanılır."
      }
    },
    "android": {
      "package": "com.nebiozkan.akrep",
      "versionCode": 109,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Uygulamayı ve indirdiğiniz videoları korumak için Face ID kullanılır."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
